# ─────────────────────────────────────────────────────────────────────────────
# IT Ticketing System — Environment Variables. Copy to .env and fill REQUIRED.
# Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Database — REQUIRED
DATABASE_URL=postgresql://helpdesk:helpdesk_dev@localhost:5432/it_ticketing?schema=public
POSTGRES_DB=it_ticketing
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk_dev

# JWT — REQUIRED. Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production
BACKEND_PORT=5000
FRONTEND_PORT=3000

# CORS — REQUIRED
FRONTEND_URL=https://your-app.netlify.app
ALLOWED_ORIGINS=

# SMTP — optional, degrades gracefully if unset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="IT Helpdesk <your@gmail.com>"

LOG_LEVEL=info

# Frontend build-time — REQUIRED
REACT_APP_API_URL=https://your-backend.railway.app/api
